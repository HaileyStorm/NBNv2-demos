<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="using:Nbn.Demos.Basics.Ui"
        xmlns:vm="using:Nbn.Demos.Basics.Ui.ViewModels"
        mc:Ignorable="d"
        x:Class="Nbn.Demos.Basics.Ui.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1320"
        Height="980"
        MinWidth="1120"
        MinHeight="820"
        Title="Basics UI"
        Background="#F5F1E8">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <Grid RowDefinitions="Auto,*" Margin="24">
            <Border Grid.Row="0"
                    Background="#132033"
                    CornerRadius="18"
                    Padding="20"
                    Margin="0,0,0,18">
                <Grid>
                    <StackPanel Spacing="8">
                        <TextBlock Text="Basics"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="#F7F2E7" />
                        <TextBlock Text="Shared configuration and metrics UI for the template-seeded 2→2 Basics environment."
                                   Foreground="#D5C9B5"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  ColumnDefinitions="1.3*,1*"
                  RowDefinitions="Auto,Auto,Auto,Auto,*"
                  ColumnSpacing="18"
                  RowSpacing="18">
                <Border Grid.Row="0"
                        Grid.Column="0"
                        Background="#FFFDFC"
                        BorderBrush="#D9D0C2"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="18">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Connection"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#182436" />
                        <Grid ColumnDefinitions="Auto,*"
                              RowDefinitions="Auto,Auto,Auto,Auto"
                              ColumnSpacing="12"
                              RowSpacing="10">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IO address" VerticalAlignment="Center" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding IoAddress}" Watermark="{Binding DefaultIoAddressHint}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Gateway name" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding IoGatewayName}" Watermark="io-gateway" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Client name" VerticalAlignment="Center" />
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ClientName}" Watermark="nbn.basics.ui" />

                            <Grid Grid.Row="3"
                                  Grid.ColumnSpan="2"
                                  ColumnDefinitions="Auto,120,Auto,120,Auto,120"
                                  RowDefinitions="Auto,Auto"
                                  ColumnSpacing="10"
                                  RowSpacing="10">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Bind host" VerticalAlignment="Center" />
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding BindHost}" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Port" VerticalAlignment="Center" />
                                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding PortText}" />
                                <TextBlock Grid.Row="0" Grid.Column="4" Text="Timeout (s)" VerticalAlignment="Center" />
                                <TextBox Grid.Row="0" Grid.Column="5" Text="{Binding RequestTimeoutSecondsText}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Advertise host" VerticalAlignment="Center" />
                                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="5" Text="{Binding AdvertiseHost}" Watermark="{Binding DefaultAdvertiseHostHint}" />
                            </Grid>
                        </Grid>

                        <Expander Header="Optional Operator Endpoints"
                                  IsExpanded="False">
                            <Grid Margin="0,10,0,0"
                                  ColumnDefinitions="Auto,*"
                                  RowDefinitions="Auto,Auto"
                                  ColumnSpacing="12"
                                  RowSpacing="10">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Settings address" VerticalAlignment="Center" />
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding OptionalSettingsAddress}" Watermark="optional" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Settings actor" VerticalAlignment="Center" />
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding OptionalSettingsActorName}" />
                            </Grid>
                        </Expander>

                        <Expander Header="Local Worker Launcher"
                                  IsExpanded="False">
                            <StackPanel Margin="0,10,0,0"
                                        Spacing="10">
                                <TextBlock Text="Starts local WorkerNode processes on consecutive loopback ports. Shared-port multi-worker launch is not supported here yet."
                                           Foreground="#425466"
                                           TextWrapping="Wrap" />
                                <Grid ColumnDefinitions="Auto,90,Auto,90,Auto,90"
                                      ColumnSpacing="12"
                                      RowSpacing="10">
                                    <TextBlock Grid.Column="0" Text="Workers" VerticalAlignment="Center"
                                               ToolTip.Tip="How many local worker processes to start from this UI action." />
                                    <TextBox Grid.Column="1" Text="{Binding WorkerCountText}" />
                                    <TextBlock Grid.Column="2" Text="First port" VerticalAlignment="Center"
                                               ToolTip.Tip="Starting port for the launched worker set. Basics will skip ports already in use." />
                                    <TextBox Grid.Column="3" Text="{Binding WorkerBasePortText}" />
                                    <TextBlock Grid.Column="4" Text="Storage %" VerticalAlignment="Center"
                                               ToolTip.Tip="Worker storage availability percentage passed to the WorkerNode runtime." />
                                    <TextBox Grid.Column="5" Text="{Binding WorkerStoragePctText}" />
                                </Grid>
                                <Grid ColumnDefinitions="Auto,Auto,*"
                                      ColumnSpacing="12">
                                    <Button Grid.Column="0"
                                            Content="Start Workers"
                                            Command="{Binding StartWorkersCommand}"
                                            MinWidth="130" />
                                    <Button Grid.Column="1"
                                            Content="Stop Launched Workers"
                                            Command="{Binding StopWorkersCommand}"
                                            MinWidth="170" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding WorkerLauncherStatus}"
                                               VerticalAlignment="Center"
                                               Foreground="#425466"
                                               TextWrapping="Wrap" />
                                </Grid>
                                <TextBlock Text="{Binding WorkerLauncherDetail}"
                                           Foreground="#6C7A89"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Expander>

                        <Grid ColumnDefinitions="Auto,Auto,*"
                              ColumnSpacing="12">
                            <Button Grid.Column="0"
                                    Content="Connect"
                                    Command="{Binding ConnectCommand}"
                                    MinWidth="120" />
                            <Button Grid.Column="1"
                                    Content="Disconnect"
                                    Command="{Binding DisconnectCommand}"
                                    MinWidth="120" />
                            <TextBlock Grid.Column="2"
                                       VerticalAlignment="Center"
                                       Text="{Binding ValidationSummary}"
                                       ToolTip.Tip="{Binding ValidationDetails}"
                                       Foreground="#7A5E2C"
                                       TextWrapping="Wrap" />
                        </Grid>
                        <TextBlock Text="{Binding ConnectionStatus}"
                                   Foreground="#425466"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="0"
                        Grid.Column="1"
                        Background="#FFFDFC"
                        BorderBrush="#D9D0C2"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="18">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Task + Seed Family"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#182436" />
                        <Grid ColumnDefinitions="Auto,*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                              ColumnSpacing="12"
                              RowSpacing="10">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Task" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="0" Grid.Column="1"
                                      ItemsSource="{Binding Tasks}"
                                      SelectedItem="{Binding SelectedTask}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TaskOption">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" />
                                            <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="#6C7A89" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Output mode" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="1" Grid.Column="1"
                                      ItemsSource="{Binding OutputObservationModes}"
                                      SelectedItem="{Binding SelectedOutputObservationMode}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:OutputObservationModeOption">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" />
                                            <TextBlock Text="{Binding DetailText}" FontSize="11" Foreground="#6C7A89" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Template ID" VerticalAlignment="Center" />
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding TemplateId}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Description" VerticalAlignment="Center" />
                            <TextBox Grid.Row="3" Grid.Column="1"
                                     Text="{Binding TemplateDescription}"
                                     AcceptsReturn="True"
                                     Height="72"
                                     TextWrapping="Wrap" />

                            <Grid Grid.Row="4"
                                  Grid.ColumnSpan="2"
                                  ColumnDefinitions="Auto,Auto,Auto,Auto"
                                  ColumnSpacing="16">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Input width" FontSize="12" Foreground="#6C7A89" />
                                    <TextBlock Text="{Binding InputWidthDisplay}" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Output width" FontSize="12" Foreground="#6C7A89" />
                                    <TextBlock Text="{Binding OutputWidthDisplay}" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Bootstrap species" FontSize="12" Foreground="#6C7A89" />
                                    <TextBlock Text="{Binding ExpectSingleBootstrapSpeciesDisplay}" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="Off-template seeds" FontSize="12" Foreground="#6C7A89" />
                                    <TextBlock Text="{Binding AllowOffTemplateSeedsDisplay}" FontWeight="SemiBold" />
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <Expander Header="Optional Template Artifact"
                                  IsExpanded="False">
                            <Grid Margin="0,10,0,0"
                                  ColumnDefinitions="Auto,*"
                                  RowDefinitions="Auto,Auto,Auto,Auto"
                                  ColumnSpacing="12"
                                  RowSpacing="10">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="SHA-256" VerticalAlignment="Center" />
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TemplateArtifactSha256}" Watermark="64-char hex" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Media type" VerticalAlignment="Center" />
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TemplateArtifactMediaType}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Size bytes" VerticalAlignment="Center" />
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding TemplateArtifactSizeBytesText}" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Store URI" VerticalAlignment="Center" />
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding TemplateArtifactStoreUri}" />
                            </Grid>
                        </Expander>

                        <Expander Header="Initial Brains"
                                  IsExpanded="False">
                            <StackPanel Margin="0,10,0,0"
                                        Spacing="10">
                                <TextBlock Text="Uploaded .nbn files replace the built template for initial seeding. Each unique upload becomes a seed template, and checked uploads contribute an extra exact copy for reproduction."
                                           Foreground="#425466"
                                           TextWrapping="Wrap" />
                                <Grid ColumnDefinitions="Auto,Auto,*"
                                      ColumnSpacing="12">
                                    <Button Grid.Column="0"
                                            Content="Add .nbn Files"
                                            Command="{Binding AddInitialBrainsCommand}"
                                            MinWidth="130" />
                                    <Button Grid.Column="1"
                                            Content="Clear"
                                            Command="{Binding ClearInitialBrainsCommand}"
                                            MinWidth="90" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding InitialBrainSeedStatus}"
                                               VerticalAlignment="Center"
                                               Foreground="#425466"
                                               TextWrapping="Wrap" />
                                </Grid>
                                <ItemsControl ItemsSource="{Binding InitialBrainSeeds}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:InitialBrainSeedItemViewModel">
                                            <Border Margin="0,0,0,8"
                                                    Background="#FBF8F1"
                                                    BorderBrush="#E5DECF"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="10">
                                                <Grid ColumnDefinitions="*,Auto,Auto"
                                                      ColumnSpacing="12">
                                                    <StackPanel Grid.Column="0"
                                                                Spacing="4">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#182436" />
                                                        <TextBlock Text="{Binding LocalPath}"
                                                                   FontSize="11"
                                                                   Foreground="#6C7A89"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding Complexity.InternalNeuronCount, StringFormat='internal_neurons={0}'}"
                                                                   FontSize="11"
                                                                   Foreground="#6C7A89" />
                                                        <TextBlock Text="{Binding Complexity.AxonCount, StringFormat='axons={0}'}"
                                                                   FontSize="11"
                                                                   Foreground="#6C7A89" />
                                                    </StackPanel>
                                                    <CheckBox Grid.Column="1"
                                                              Content="Duplicate"
                                                              IsChecked="{Binding DuplicateForReproduction}"
                                                              VerticalAlignment="Center" />
                                                    <Button Grid.Column="2"
                                                            Content="Remove"
                                                            Command="{Binding RemoveCommand}"
                                                            MinWidth="90"
                                                            VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Background="#FFFDFC"
                        BorderBrush="#D9D0C2"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="18">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Task Settings"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#182436" />
                        <TextBlock Text="{Binding TaskSettingsDetail}"
                                   Foreground="#425466"
                                   TextWrapping="Wrap" />

                        <Grid ColumnDefinitions="Auto,120,Auto,120,*"
                              RowDefinitions="Auto"
                              ColumnSpacing="12"
                              RowSpacing="10">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Ready window ticks" VerticalAlignment="Center"
                                       ToolTip.Tip="Maximum number of post-input ticks to wait for the shared ready bit before a sample is treated as not ready." />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding MaxReadyWindowTicksText}" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Sample repeats" VerticalAlignment="Center"
                                       ToolTip.Tip="How many times to run each canonical sample before averaging its output into one scored observation." />
                            <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding SampleRepeatCountText}" />
                        </Grid>

                        <Grid IsVisible="{Binding ShowBooleanTaskSettings}"
                              ColumnDefinitions="Auto,120,Auto,120,*"
                              RowDefinitions="Auto,Auto"
                              ColumnSpacing="12"
                              RowSpacing="10">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Low input" VerticalAlignment="Center"
                                       ToolTip.Tip="Numeric value used for the false branch of the truth table." />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding BooleanLowInputValueText}" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="High input" VerticalAlignment="Center"
                                       ToolTip.Tip="Numeric value used for the true branch of the truth table." />
                            <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding BooleanHighInputValueText}" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5"
                                       Text="AND, OR, and XOR still evaluate exactly four samples; these values only change the low/high coordinates of that truth table."
                                       Foreground="#6C7A89"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <Grid IsVisible="{Binding ShowGtTaskSettings}"
                              ColumnDefinitions="Auto,120,*"
                              RowDefinitions="Auto,Auto"
                              ColumnSpacing="12"
                              RowSpacing="10">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Unique input values" VerticalAlignment="Center"
                                       ToolTip.Tip="Number of evenly spaced scalar values to place on each GT input axis. Dataset size is this count squared." />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding GtUniqueInputValuesText}" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                       Text="GT uses an evenly spaced comparison grid in [0,1] and scores output 1 only when A is strictly greater than B."
                                       Foreground="#6C7A89"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <Grid IsVisible="{Binding ShowMultiplicationTaskSettings}"
                              ColumnDefinitions="Auto,120,Auto,120,*"
                              RowDefinitions="Auto,Auto"
                              ColumnSpacing="12"
                              RowSpacing="10">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Unique input values" VerticalAlignment="Center"
                                       ToolTip.Tip="Number of evenly spaced scalar values to place on each multiplication input axis. Basics evaluates all interior points plus a deterministic subset of boundary cases so 0/1 edges do not dominate small grids." />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding MultiplicationUniqueInputValuesText}" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Accuracy tolerance" VerticalAlignment="Center"
                                       ToolTip.Tip="Maximum absolute output error still counted as accurate for multiplication scoring." />
                            <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding MultiplicationToleranceText}" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5"
                                       Text="Multiplication uses a stratified deterministic subset of the selected [0,1] grid, preserves all interior points, and exposes raw, balanced, edge, and interior accuracy views."
                                       Foreground="#6C7A89"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <TextBlock IsVisible="{Binding ShowUnavailableTaskSettingsMessage}"
                                   Text="This task does not expose custom evaluation settings yet."
                                   Foreground="#6C7A89"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Grid.Column="0"
                        Background="#FFFDFC"
                        BorderBrush="#D9D0C2"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="18">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Seed Family + Divergence"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#182436" />
                        <Grid ColumnDefinitions="Auto,120,Auto,120"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                              ColumnSpacing="12"
                              RowSpacing="10">
                            <TextBlock Grid.Row="0" Grid.ColumnSpan="4" Text="Initial seed-shape bounds" FontWeight="SemiBold" Foreground="#425466" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Min internal regions" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MinActiveInternalRegionCountText}" Watermark="{Binding MinActiveInternalRegionCountWatermark}" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Max internal regions" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding MaxActiveInternalRegionCountText}" Watermark="{Binding MaxActiveInternalRegionCountWatermark}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Min internal neurons" VerticalAlignment="Center" />
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MinInternalNeuronCountText}" Watermark="{Binding MinInternalNeuronCountWatermark}" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Max internal neurons" VerticalAlignment="Center" />
                            <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding MaxInternalNeuronCountText}" Watermark="{Binding MaxInternalNeuronCountWatermark}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Min axons" VerticalAlignment="Center" />
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding MinAxonCountText}" Watermark="{Binding MinAxonCountWatermark}" />
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="Max axons" VerticalAlignment="Center" />
                            <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding MaxAxonCountText}" Watermark="{Binding MaxAxonCountWatermark}" />

                            <TextBlock Grid.Row="4" Grid.ColumnSpan="4" Text="Bounded divergence from template" FontWeight="SemiBold" Foreground="#425466" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Internal neuron delta" VerticalAlignment="Center" />
                            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding MaxInternalNeuronDeltaText}" />
                            <TextBlock Grid.Row="5" Grid.Column="2" Text="Axon delta" VerticalAlignment="Center" />
                            <TextBox Grid.Row="5" Grid.Column="3" Text="{Binding MaxAxonDeltaText}" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,120,Auto,120"
                              RowDefinitions="Auto,Auto"
                              ColumnSpacing="12"
                              RowSpacing="10">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Strength-code delta" VerticalAlignment="Center" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding MaxStrengthCodeDeltaText}" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Param-code delta" VerticalAlignment="Center" />
                            <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding MaxParameterCodeDeltaText}" />

                            <CheckBox Grid.Row="1" Grid.Column="0" Content="Allow function mutation" IsChecked="{Binding AllowFunctionMutation}" />
                            <CheckBox Grid.Row="1" Grid.Column="1" Content="Allow axon reroute" IsChecked="{Binding AllowAxonReroute}" />
                            <CheckBox Grid.Row="1" Grid.Column="2" Content="Allow region-set change" IsChecked="{Binding AllowRegionSetChange}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Grid.Column="1"
                        Background="#FFFDFC"
                        BorderBrush="#D9D0C2"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="18">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Capacity + Bounds"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#182436" />
                        <TextBlock Text="{Binding CapacitySummary}"
                                   TextWrapping="Wrap"
                                   Foreground="#425466" />
                        <TextBlock Text="{Binding CapacityStatus}"
                                   TextWrapping="Wrap"
                                   Foreground="#6C7A89" />
                        <Grid ColumnDefinitions="Auto,110,Auto,110,*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                              ColumnSpacing="12"
                              RowSpacing="10">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Initial population" VerticalAlignment="Center"
                                       ToolTip.Tip="Number of brains to seed into each generation. Basics keeps this at 2 or more so reproduction can continue." />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding InitialPopulationOverrideText}" Watermark="auto"
                                     ToolTip.Tip="Override the generation population size. Leave blank to use the task/capacity default." />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Suggested" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding RecommendedInitialPopulationText}" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Min population" VerticalAlignment="Center"
                                       ToolTip.Tip="Hard lower bound for any generation. If reproduction under-produces, Basics carries forward enough brains to stay above this floor when possible." />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MinimumPopulationOverrideText}" Watermark="2" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Max population" VerticalAlignment="Center"
                                       ToolTip.Tip="Hard upper bound for any generation. The target population is clamped into this range." />
                            <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding MaximumPopulationOverrideText}" Watermark="auto" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Base run count" VerticalAlignment="Center"
                                       ToolTip.Tip="Baseline reproduction run budget per selected parent pair before the Min/Max runs-per-pair scheduler reshapes it." />
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ReproductionRunCountOverrideText}" Watermark="auto"
                                     ToolTip.Tip="Capacity-side baseline for how many child attempts to request from a selected parent pair." />
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Suggested" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding RecommendedRunCountText}" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Max concurrent" VerticalAlignment="Center"
                                       ToolTip.Tip="How many brains Basics is allowed to spawn and evaluate at once within a generation." />
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding MaxConcurrentBrainsOverrideText}" Watermark="auto"
                                     ToolTip.Tip="Hard cap on simultaneously active evaluation brains." />
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="Suggested" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding RecommendedMaxConcurrentBrainsText}" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Stop accuracy" VerticalAlignment="Center"
                                       ToolTip.Tip="Stop once a generation reaches at least this accuracy." />
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding TargetAccuracyText}"
                                     ToolTip.Tip="Accuracy threshold for declaring the run solved." />
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="Stop fitness" VerticalAlignment="Center"
                                       ToolTip.Tip="Stop once a generation reaches at least this fitness." />
                            <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding TargetFitnessText}"
                                     ToolTip.Tip="Fitness threshold for declaring the run solved." />
                            <CheckBox Grid.Row="4" Grid.Column="4"
                                      Content="Require both"
                                      IsChecked="{Binding RequireBothStopTargets}"
                                      VerticalAlignment="Center"
                                      ToolTip.Tip="When checked, Basics requires both stop thresholds to be met. When unchecked, either threshold can end the run." />

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Max generations" VerticalAlignment="Center"
                                       ToolTip.Tip="Optional hard cap on how many generations to evaluate. Leave blank for no generation limit." />
                            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding MaximumGenerationsText}" Watermark="unlimited"
                                     ToolTip.Tip="Stop after this many evaluated generations even if the accuracy/fitness target has not been reached." />
                            <TextBlock Grid.Row="5" Grid.Column="2" Grid.ColumnSpan="2"
                                       Text="blank = unlimited"
                                       VerticalAlignment="Center"
                                       Foreground="#6C7A89" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto"
                              ColumnSpacing="12">
                            <Button Grid.Column="0"
                                    Content="Start"
                                    Command="{Binding StartCommand}"
                                    MinWidth="110" />
                            <Button Grid.Column="1"
                                    Content="Stop"
                                    Command="{Binding StopCommand}"
                                    MinWidth="110" />
                            <Button Grid.Column="2"
                                    Content="Fetch Capacity"
                                    Command="{Binding FetchCapacityCommand}"
                                    MinWidth="130" />
                            <Button Grid.Column="3"
                                    Content="Apply Suggested Bounds"
                                    Command="{Binding ApplySuggestedBoundsCommand}"
                                    MinWidth="180" />
                        </Grid>
                        <TextBlock Text="{Binding LastPlanSummary}"
                                   TextWrapping="Wrap"
                                   Foreground="#6C7A89" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="3"
                        Grid.Column="0"
                        Background="#FFFDFC"
                        BorderBrush="#D9D0C2"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="18">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Reproduction + Speciation Scheduling"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#182436" />
                        <Grid ColumnDefinitions="Auto,140,Auto,140,Auto,140"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                              ColumnSpacing="12"
                              RowSpacing="10">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Strength source" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="0" Grid.Column="1"
                                      ItemsSource="{Binding StrengthSources}"
                                      SelectedItem="{Binding SelectedStrengthSource}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:StrengthSourceOption">
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Protect IO neurons" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding ProtectIoRegionNeuronCountsDisplay}" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="Diversity preset" VerticalAlignment="Center"
                                       ToolTip.Tip="Fast control for overall exploration pressure. It adjusts scheduling plus hidden reproduction mutation probabilities, and adaptive stall boost escalates it automatically during plateaus." />
                            <ComboBox Grid.Row="0" Grid.Column="5"
                                      ItemsSource="{Binding DiversityPresets}"
                                      SelectedItem="{Binding SelectedDiversityPreset}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:DiversityPresetOption">
                                        <TextBlock Text="{Binding DisplayName}" ToolTip.Tip="{Binding DetailText}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Fitness weight" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding FitnessWeightText}" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Diversity weight" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding DiversityWeightText}" />
                            <TextBlock Grid.Row="1" Grid.Column="4" Text="Species-balance" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="5" Text="{Binding SpeciesBalanceWeightText}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Elite fraction" VerticalAlignment="Center"
                                       ToolTip.Tip="Fraction of the ranked population that is automatically carried into the next generation before breeding fills the rest." />
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding EliteFractionText}" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Exploration" VerticalAlignment="Center"
                                       ToolTip.Tip="Fraction of parent slots reserved for lower-ranked exploratory picks instead of purely score-ranked picks." />
                            <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding ExplorationFractionText}" />
                            <TextBlock Grid.Row="2" Grid.Column="4" Text="Fitness exponent" VerticalAlignment="Center" />
                            <TextBox Grid.Row="2" Grid.Column="5" Text="{Binding FitnessExponentText}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Max parents/species" VerticalAlignment="Center"
                                       ToolTip.Tip="Caps how many parent candidates any one species can contribute before exploration picks from the remainder." />
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding MaxParentsPerSpeciesText}" />
                            <CheckBox Grid.Row="3" Grid.Column="2"
                                      Content="Adaptive stall boost"
                                      IsChecked="{Binding AdaptiveDiversityEnabled}"
                                      VerticalAlignment="Center"
                                      ToolTip.Tip="When enabled, Basics increases diversity pressure after a task-specific number of stagnant generations." />
                            <TextBlock Grid.Row="3" Grid.Column="4" Text="Stall window" VerticalAlignment="Center"
                                       ToolTip.Tip="Number of consecutive non-improving generations before the adaptive diversity bump begins." />
                            <TextBox Grid.Row="3" Grid.Column="5" Text="{Binding AdaptiveDiversityStallGenerationWindowText}" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="6"
                                       Text="Adaptive stall boost is on by default for every task. Task defaults currently use shorter windows for easier tasks and a longer window for multiplication."
                                       Foreground="#6C7A89"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,120,Auto,120,Auto,120"
                              ColumnSpacing="12">
                            <TextBlock Grid.Column="0" Text="Min runs/pair" VerticalAlignment="Center"
                                       ToolTip.Tip="Lower bound for how many reproduction attempts a selected parent pair receives after scheduler weighting." />
                            <TextBox Grid.Column="1" Text="{Binding MinRunsPerPairText}" />
                            <TextBlock Grid.Column="2" Text="Max runs/pair" VerticalAlignment="Center"
                                       ToolTip.Tip="Upper bound for how many reproduction attempts a selected parent pair receives after scheduler weighting and the base run count cap." />
                            <TextBox Grid.Column="3" Text="{Binding MaxRunsPerPairText}" />
                            <TextBlock Grid.Column="4" Text="Diversity boost" VerticalAlignment="Center" />
                            <TextBox Grid.Column="5" Text="{Binding DiversityBoostText}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="3"
                        Grid.Column="1"
                        Background="#FFFDFC"
                        BorderBrush="#D9D0C2"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="18">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Best Brain"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#182436" />
                        <TextBlock Text="{Binding BestBrainStatus}"
                                   TextWrapping="Wrap"
                                   FontWeight="SemiBold"
                                   Foreground="#425466" />
                        <TextBlock Text="{Binding BestBrainDetail}"
                                   TextWrapping="Wrap"
                                   Foreground="#6C7A89" />
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12">
                            <Button Grid.Column="0"
                                    Content="Export best available"
                                    Command="{Binding ExportBestCommand}"
                                    MinWidth="180" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding WinnerExportStatus}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       Foreground="#425466" />
                        </Grid>
                        <TextBlock Text="{Binding WinnerExportDetail}"
                                   TextWrapping="Wrap"
                                   Foreground="#6C7A89" />
                        <ItemsControl ItemsSource="{Binding BestBrainSummaries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:MetricSummaryItemViewModel">
                                    <Border Margin="0,0,0,8"
                                            Background="#FBF8F1"
                                            BorderBrush="#E5DECF"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="10"
                                            ToolTip.Tip="{Binding DetailText}">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold"
                                                       Foreground="#182436" />
                                            <TextBlock Text="{Binding ValueText}"
                                                       FontSize="20"
                                                       Foreground="#182436" />
                                            <TextBlock Text="{Binding DetailText}"
                                                       FontSize="12"
                                                       Foreground="#6C7A89"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Row="4"
                        Grid.ColumnSpan="2"
                        Background="#FFFDFC"
                        BorderBrush="#D9D0C2"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="18">
                    <Grid ColumnDefinitions="1.2*,1.2*,1*"
                          ColumnSpacing="18">
                        <StackPanel Grid.Column="0" Spacing="10">
                            <TextBlock Text="Accuracy Over Time"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#182436" />
                            <WrapPanel IsVisible="{Binding ShowAccuracyMetricToggles}"
                                       ItemSpacing="12">
                                <CheckBox Content="Balanced"
                                          IsChecked="{Binding ShowBalancedAccuracyChart}"
                                          Foreground="#2563EB" />
                                <CheckBox Content="Edge"
                                          IsChecked="{Binding ShowEdgeAccuracyChart}"
                                          Foreground="#D97706" />
                                <CheckBox Content="Interior"
                                          IsChecked="{Binding ShowInteriorAccuracyChart}"
                                          Foreground="#9F1239" />
                            </WrapPanel>
                            <Border BorderBrush="#D9D0C2"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="6"
                                    Background="#FBF8F1"
                                    Height="720">
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="8"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch">
                                    <LayoutTransformControl Grid.Column="0"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center">
                                        <LayoutTransformControl.LayoutTransform>
                                            <RotateTransform Angle="-90" />
                                        </LayoutTransformControl.LayoutTransform>
                                        <TextBlock Text="Accuracy"
                                                   FontSize="12"
                                                   Foreground="#6C7A89" />
                                    </LayoutTransformControl>
                                    <ui:MetricLineChart Grid.Column="1"
                                                        PrimaryValues="{Binding AccuracyChartValues}"
                                                        SecondaryValues="{Binding BestAccuracyChartValues}"
                                                        TertiaryValues="{Binding AccuracyTertiaryChartValues}"
                                                        QuaternaryValues="{Binding AccuracyQuaternaryChartValues}"
                                                        PrimaryStroke="#2563EB"
                                                        SecondaryStroke="#1E3A8A"
                                                        TertiaryStroke="#D97706"
                                                        QuaternaryStroke="#9F1239"
                                                        EmptyText="No runtime accuracy samples yet."
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch" />
                                </Grid>
                            </Border>
                            <TextBlock Text="{Binding MetricsStatus}"
                                       Foreground="#425466"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="10">
                            <TextBlock Text="Fitness Over Time"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#182436" />
                            <Border BorderBrush="#D9D0C2"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="6"
                                    Background="#FBF8F1"
                                    Height="720">
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="8"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch">
                                    <LayoutTransformControl Grid.Column="0"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center">
                                        <LayoutTransformControl.LayoutTransform>
                                            <RotateTransform Angle="-90" />
                                        </LayoutTransformControl.LayoutTransform>
                                        <TextBlock Text="Fitness"
                                                   FontSize="12"
                                                   Foreground="#6C7A89" />
                                    </LayoutTransformControl>
                                    <ui:MetricLineChart Grid.Column="1"
                                                        PrimaryValues="{Binding FitnessChartValues}"
                                                        SecondaryValues="{Binding BestFitnessChartValues}"
                                                        PrimaryStroke="#A16207"
                                                        SecondaryStroke="#92400E"
                                                        EmptyText="No runtime fitness samples yet."
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch" />
                                </Grid>
                            </Border>
                            <TextBlock Text="{Binding MetricsSecondaryStatus}"
                                       Foreground="#425466"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ExecutionStatus}"
                                       Foreground="#425466"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ExecutionDetail}"
                                       Foreground="#6C7A89"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ExecutionLogPath}"
                                       Foreground="#6C7A89"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="10">
                            <TextBlock Text="Metric Summary"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#182436" />
                            <ItemsControl ItemsSource="{Binding MetricSummaries}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MetricSummaryItemViewModel">
                                        <Border Margin="0,0,0,8"
                                                Background="#FBF8F1"
                                                BorderBrush="#E5DECF"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="10"
                                                ToolTip.Tip="{Binding DetailText}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#182436" />
                                                <TextBlock Text="{Binding ValueText}"
                                                           FontSize="20"
                                                           Foreground="#182436" />
                                                <TextBlock Text="{Binding DetailText}"
                                                           FontSize="12"
                                                           Foreground="#6C7A89"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
